EPROC = '/content/preprocessed'\n","if not os.path.exists(LOCAL_PREPROC):\n","    os.makedirs(LOCAL_PREPROC, exist_ok=True)\n","    print('Copying VAE latents to local...')\n","    shutil.copytree(os.path.join(PREPROC, 'vae_latents'), os.path.join(LOCAL_PREPROC, 'vae_latents'))\n","    print('Copying SAM2 features to local...')\n","    shutil.copytree(os.path.join(PREPROC, 'sam2_features'), os.path.join(LOCAL_PREPROC, 'sam2_features'))\n","    print('Local copy done!')\n","else:\n","    print('Local cache exists.')\n","\n","class LOLv2FullDataset(Dataset):\n","    \"\"\"Returns: low_latent, gt_latent, sam2_feat, gt_rgb, low_img_path\"\"\"\n","    def __init__(self, dataset_name='LOLv2_Real', split='Train', augment=False):\n","        self.latent_dir = os.path.join(LOCAL_PREPROC, 'vae_latents')\n","        self.feat_dir = os.path.join(LOCAL_PREPROC, 'sam2_features')\n","        self.augment = augment\n","\n","        input_dir = os.path.join(DATASETS, f'{dataset_name}/{split}/Input')\n","        gt_dir = os.path.join(DATASETS, f'{dataset_name}/{split}/GT')\n","\n","        image_files = sorted(glob.glob(os.path.join(input_dir, '*.png')))\n","        image_files += sorted(glob.glob(os.path.join(input_dir, '*.jpg')))\n","\n","        self.samples = []\n","        for img_path in image_files:\n","            name = os.path.splitext(os.path.basename(img_path))[0]\n","            low_lat = os.path.join(self.latent_dir, f'Input_{name}.pt')\n","            gt_lat = os.path.join(self.latent_dir, f'GT_{name}.pt')\n","            feat = os.path.join(self.feat_dir, f'{name}.pt')\n","            # Try multiple GT naming conventions\n","            gt_img = os.path.join(gt_dir, os.path.basename(img_path))\n","            if not os.path.exists(gt_img):\n","                gt_img = os.path.join(gt_dir, name + '.png')\n","            if not os.path.exists(gt_img):\n","                gt_img = os.path.join(gt_dir, name + '.jpg')\n","            if all(os.path.exists(p) for p in [low_lat, gt_lat, feat, gt_img]):\n","                self.samples.append((low_lat, gt_lat, feat, gt_img, img_path))\n","\n","        self.transform = transforms.Compose([\n","            transforms.Resize((400, 600)),\n","            transforms.ToTensor(),\n","        ])\n","        print(f'  {dataset_name}/{split}: {len(self.samples)} samples')\n","\n","    def __len__(self):\n","        return len(self.samples)\n","\n","    def __getitem__(self, idx):\n","        low_path, gt_path, feat_path, gt_img_path, low_img_path = self.samples[idx]\n","        low = torch.load(low_path, weights_only=True).squeeze"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"RB8lBxKR6MxH","executionInfo":{"status":"ok","timestamp":1776823970179,"user_tz":240,"elapsed":25,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"}},"outputId":"989f9604-63b4-44ee-8d59-f8e62aee3f90"},"execution_count":45,"outputs":[{"output_type":"stream","name":"stdout","text":["Local cache exists.\n"]}]},{"cell_type":"code","source":["from diffusers import UNet2DConditionModel, AutoencoderKL\n","from peft import LoraConfig, get_peft_model\n","\n","print('Loading pretrained SD U-Net...')\n","unet = UNet2DConditionModel.from_pretrained(\n","    'sd-legacy/stable-diffusion-v1-5', subfolder='unet', torch_dtype=torch.float32\n",").to('cuda')\n","unet.requires_grad_(False)\n","\n","lora_config = LoraConfig(\n","    r=16, lora_alpha=16,\n","    target_modules=['to_q', 'to_v', 'to_k', 'to_out.0', 'proj_in', 'proj_out', 'ff.net.0.proj', 'ff.net.2'],\n","    lora_dropout=0.05,\n",")\n","unet = get_peft_model(unet, lora_config)\n","\n","class SAM2Adapter(nn.Module):\n","    def __init__(self, sam2_dim=256, sd_cross_dim=768, seq_len=77):\n","        super().__init__()\n","        self.proj = nn.Sequential(\n","            nn.Conv2d(sam2_dim, sd_cross_dim, 1), nn.GELU(),\n","            nn.Conv2d(sd_cross_dim, sd_cross_dim, 1),\n","        )\n","        self.seq_len = seq_len\n","    def forward(self, f):\n","        x = self.proj(f)\n","        B, C, H, W = x.shape\n","        x = x.view(B, C, H * W).permute(0, 2, 1)\n","        if x.shape[1] > self.seq_len:\n","            x = F.adaptive_avg_pool1d(x.permute(0, 2, 1), self.seq_len).permute(0, 2, 1)\n","        return x\n","\n","sam2_adapter = SAM2Adapter().to('cuda')\n","\n","# 8-channel conv_in\n","old_conv = unet.base_model.model.conv_in\n","new_conv = nn.Conv2d(8, old_conv.out_channels, old_conv.kernel_size, old_conv.stride, old_conv.padding).to('cuda')\n","with torch.no_grad():\n","    new_conv.weight[:, :4] = old_conv.weight\n","    new_conv.weight[:, 4:] = 0.0\n","    new_conv.bias = old_conv.bias\n","unet.base_model.model.conv_in = new_conv\n","\n","# Load best checkpoint\n","save_dir = os.path.join(BASE, 'checkpoints/our_model_v5_lora')\n","ft_path = os.path.join(save_dir, 'best_finetuned.pt')\n","v5_path = os.path.join(save_dir, 'best.pt')\n","ckpt_path = ft_path if os.path.exists(ft_path) else v5_path\n","print(f'Loading checkpoint: {os.path.basename(ckpt_path)}')\n","\n","ckpt = torch.load(ckpt_path, weights_only=True)\n","sam2_adapter.load_state_dict(ckpt['sam2_adapter'])\n","unet.base_model.model.conv_in.load_state_dict(ckpt['conv_in'])\n","current_state = unet.state_dict()\n","for k, v in ckpt['unet_lora'].items():\n","    if k in current_state:\n","        current_state[k] = v\n","unet.load_state_dict(current_state)\n","\n","# FREEZE everything\n","unet.eval()\n","sam2_adapter.eval()\n","for p in unet.parameters(): p.requires_grad_(False)\n","for p in sam2_adapter.parameters(): p.requires_grad_(False)\n","\n","# Load VAE\n","vae = AutoencoderKL.from_pretrained(\n","    os.path.join(BASE, 'checkpoints/vae'), torch_dtype=torch.float16\n",").to('cuda')\n","vae.eval()\n","for p in vae.parameters(): p.requires_grad_(False)\n","\n","def decode_latent(vae, latent):\n","    with torch.no_grad():\n","        img = vae.decode(latent.half() / 0.18215).sample\n","    return (img.float().clamp(-1, 1) * 0.5 + 0.5)\n","\n","@torch.no_grad()\n","def run_sam2_latentdiff(low, feat):\n","    x_in = torch.cat([low, low], dim=1)\n","    sam2_ctx = sam2_adapter(feat)\n","    t_zero = torch.zeros(low.shape[0], dtype=torch.long, device='cuda')\n","    with autocast():\n","        pred = unet(x_in, t_zero, encoder_hidden_states=sam2_ctx).sample\n","    return low + pred\n","\n","@torch.no_grad()\n","def run_no_sam2(low):\n","    \"\"\"Ablation A: zero SAM2 features\"\"\"\n","    x_in = torch.cat([low, low], dim=1)\n","    zero_ctx = torch.zeros(low.shape[0], 77, 768, device='cuda')\n","    t_zero = torch.zeros(low.shape[0], dtype=torch.long, device='cuda')\n","    with autocast():\n","        pred = unet(x_in, t_zero, encoder_hidden_states=zero_ctx).sample\n","    return low + pred\n","\n","print('All frozen components loaded. Ready for PixelRefiner training.')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7oMtYvaK6Rr6","executionInfo":{"status":"ok","timestamp":1776824009236,"user_tz":240,"elapsed":2376,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"}},"outputId":"13882dc7-3e5e-4b77-ab67-c5bfb450f44a"},"execution_count":46,"outputs":[{"output_type":"stream","name":"stdout","text":["Loading pretrained SD U-Net...\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/huggingface_hub/utils/_validators.py:205: UserWarning: The `local_dir_use_symlinks` argument is deprecated and ignored in `hf_hub_download`. Downloading to a local directory does not use symlinks anymore.\n","  warnings.warn(\n"]},{"output_type":"stream","name":"stdout","text":["Loading checkpoint: best_finetuned.pt\n","All frozen components loaded. Ready for PixelRefiner training.\n"]}]},{"cell_type":"code","source":["class PixelRefiner(nn.Module):\n","    \"\"\"Lightweight CNN: fixes VAE artifacts and color shifts in pixel space.\n","    Inspired by DiffBIR and StableSR post-processing modules.\"\"\"\n","    def __init__(self, ch=48):\n","        super().__init__()\n","        self.net = nn.Sequential(\n","            nn.Conv2d(6, ch, 3, padding=1),   # 6 = decoded(3) + low_rgb(3)\n","            nn.GELU(),\n","            nn.Conv2d(ch, ch, 3, padding=1),\n","            nn.GELU(),\n","            nn.Conv2d(ch, ch, 3, padding=1),\n","            nn.GELU(),\n","            nn.Conv2d(ch, ch, 3, padding=1),\n","            nn.GELU(),\n","            nn.Conv2d(ch, ch, 3, padding=1),\n","            nn.GELU(),\n","        )\n","        self.out = nn.Conv2d(ch, 3, 3, padding=1)\n","        # Zero-init output: starts as identity (decoded passes through unchanged)\n","        nn.init.zeros_(self.out.weight)\n","        nn.init.zeros_(self.out.bias)\n","\n","    def forward(self, decoded, low_rgb):\n","        x = torch.cat([decoded, low_rgb], dim=1)\n","        h = self.net(x)\n","        return (decoded + self.out(h)).clamp(0, 1)\n","\n","refiner = PixelRefiner(ch=48).to('cuda')\n","n_params = sum(p.numel() for p in refiner.parameters())\n","print(f'PixelRefiner: {n_params:,} parameters ({n_params/1e6:.2f}M)')\n","\n","# Quick sanity check\n","dummy_dec = torch.rand(1, 3, 400, 600).cuda()\n","dummy_low = torch.rand(1, 3, 400, 600).cuda()\n","out = refiner(dummy_dec, dummy_low)\n","print(f'Input: {dummy_dec.shape} -> Output: {out.shape}')\n","print('PixelRefiner OK!')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"6hybn9Rh6pmQ","executionInfo":{"status":"ok","timestamp":1776824059264,"user_tz":240,"elapsed":281,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"}},"outputId":"ac6c980a-428d-4342-c872-097742a9f1ab"},"execution_count":47,"outputs":[{"output_type":"stream","name":"stdout","text":["PixelRefiner: 87,075 parameters (0.09M)\n","Input: torch.Size([1, 3, 400, 600]) -> Output: torch.Size([1, 3, 400, 600])\n","PixelRefiner OK!\n"]}]},{"cell_type":"code","source":["import lpips\n","\n","lpips_fn = lpips.LPIPS(net='alex').to('cuda')\n","lpips_fn.eval()\n","\n","# === Training config ===\n","MAX_EPOCHS = 80\n","PATIENCE = 12              # early stop after 12 epochs without improvement\n","LR = 2e-4\n","BATCH = 4\n","EMA_DECAY = 0.999\n","SAVE_DIR = os.path.join(BASE, 'checkpoints/pixel_refiner')\n","os.makedirs(SAVE_DIR, exist_ok=True)\n","save_path = os.path.join(SAVE_DIR, 'best.pt')\n","\n","optimizer = torch.optim.AdamW(refiner.parameters(), lr=LR, weight_decay=1e-4)\n","scaler = GradScaler()\n","scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=MAX_EPOCHS)\n","dataloader = DataLoader(train_dataset, batch_size=BATCH, shuffle=True,\n","                        num_workers=2, pin_memory=True, drop_last=True)\n","\n","# EMA weights\n","ema_state = copy.deepcopy(refiner.state_dict())\n","\n","# Early stopping state\n","best_loss = float('inf')\n","patience_counter = 0\n","train_log = []\n","\n","refiner.train()\n","start_time = time.time()\n","\n","for epoch in range(MAX_EPOCHS):\n","    total_loss = 0\n","    n = 0\n","    pbar = tqdm(dataloader, desc=f'Epoch {epoch+1}/{MAX_EPOCHS}')\n","\n","    for low, gt_lat, feat, gt_rgb, low_rgb in pbar:\n","        low, feat = low.cuda(), feat.cuda()\n","        gt_rgb, low_rgb = gt_rgb.cuda(), low_rgb.cuda()\n","\n","        # Forward through frozen SAM2-LatentDiff\n","        with torch.no_grad():\n","            enhanced_latent = run_sam2_latentdiff(low, feat)\n","            decoded = decode_latent(vae, enhanced_latent)\n","            low_decoded = decode_latent(vae, low)\n","\n","        # PixelRefiner (this has grad)\n","        # Use original low-light RGB as reference (more info than VAE-decoded low)\n","        refined = refiner(decoded, low_rgb)\n","\n","        # === Multi-loss ===\n","        loss_char = torch.sqrt((refined - gt_rgb) ** 2 + 1e-6).mean()\n","        loss_l2 = F.mse_loss(refined, gt_rgb)\n","        loss_lpips = lpips_fn(refined * 2 - 1, gt_rgb * 2 - 1).mean()\n","\n","        loss = loss_char + 0.3 * loss_l2 + 0.1 * loss_lpips\n","\n","        optimizer.zero_grad(set_to_none=True)\n","        scaler.scale(loss).backward()\n","        scaler.unscale_(optimizer)\n","        torch.nn.utils.clip_grad_norm_(refiner.parameters(), 1.0)\n","        scaler.step(optimizer)\n","        scaler.update()\n","\n","        # EMA update\n","        with torch.no_grad():\n","            for key in ema_state:\n","                ema_state[key] = EMA_DECAY * ema_state[key] + (1 - EMA_DECAY) * refiner.state_dict()[key]\n","\n","        total_loss += loss.item()\n","        n += 1\n","        pbar.set_postfix({'loss': f'{loss.item():.4f}'})\n","\n","    scheduler.step()\n","    avg_loss = total_loss / n\n","    train_log.append({'epoch': epoch + 1, 'loss': avg_loss, 'lr': scheduler.get_last_lr()[0]})\n","\n","    # === Early stopping check ===\n","    if avg_loss < best_loss:\n","        best_loss = avg_loss\n","        patience_counter = 0\n","        torch.save({\n","            'refiner': copy.deepcopy(ema_state),\n","            'epoch': epoch + 1,\n","            'loss': avg_loss\n","        }, save_path)\n","        marker = ' ★ SAVED'\n","    else:\n","        patience_counter += 1\n","        marker = f' (patience {patience_counter}/{PATIENCE})'\n","\n","    elapsed = time.time() - start_time\n","    print(f'  Epoch {epoch+1}: loss={avg_loss:.4f}, lr={scheduler.get_last_lr()[0]:.2e}{marker} [{elapsed/60:.1f}min]')\n","\n","    if patience_counter >= PATIENCE:\n","        print(f'\\n  Early stopping at epoch {epoch+1}. Best loss: {best_loss:.4f}')\n","        break\n","\n","print(f'\\nTraining done! Best loss: {best_loss:.4f}')\n","print(f'Checkpoint: {save_path}')\n","print(f'Total time: {(time.time()-start_time)/60:.1f} minutes')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":550},"id":"ecAipU0h94L3","executionInfo":{"status":"error","timestamp":1776824078997,"user_tz":240,"elapsed":2052,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"}},"outputId":"4f29c470-a0ef-4282