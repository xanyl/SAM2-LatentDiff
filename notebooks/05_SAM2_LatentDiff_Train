le()}')\n","print(f'GPU: {torch.cuda.get_device_name(0)}')\n","print('Ready!')"]},{"cell_type":"code","source":["import torch\n","import torch.nn as nn\n","import torch.nn.functional as F\n","import math\n","\n","class SinusoidalTimeEmbedding(nn.Module):\n","    def __init__(self, dim):\n","        super().__init__()\n","        self.dim = dim\n","        self.mlp = nn.Sequential(\n","            nn.Linear(dim, dim * 4),\n","            nn.GELU(),\n","            nn.Linear(dim * 4, dim),\n","        )\n","\n","    def forward(self, t):\n","        half = self.dim // 2\n","        freqs = torch.exp(-math.log(10000) * torch.arange(half, device=t.device) / half)\n","        emb = t[:, None].float() * freqs[None, :]\n","        emb = torch.cat([emb.sin(), emb.cos()], dim=-1)\n","        return self.mlp(emb)\n","\n","\n","class SAM2CrossAttention(nn.Module):\n","    def __init__(self, query_dim, context_dim=256, heads=8):\n","        super().__init__()\n","        self.heads = heads\n","        self.head_dim = query_dim // heads\n","        self.scale = self.head_dim ** -0.5\n","\n","        self.norm = nn.GroupNorm(8, query_dim)\n","        self.to_q = nn.Linear(query_dim, query_dim)\n","        self.to_k = nn.Linear(context_dim, query_dim)\n","        self.to_v = nn.Linear(context_dim, query_dim)\n","        self.to_out = nn.Linear(query_dim, query_dim)\n","\n","    def forward(self, x, context):\n","        b, c, h, w = x.shape\n","        x_norm = self.norm(x)\n","        x_flat = x_norm.view(b, c, h * w).permute(0, 2, 1)\n","\n","        context = F.interpolate(context, size=(h, w), mode='bilinear', align_corners=False)\n","        ctx_flat = context.view(b, context.shape[1], h * w).permute(0, 2, 1)\n","\n","        q = self.to_q(x_flat).view(b, h * w, self.heads, self.head_dim).transpose(1, 2)\n","        k = self.to_k(ctx_flat).view(b, h * w, self.heads, self.head_dim).transpose(1, 2)\n","        v = self.to_v(ctx_flat).view(b, h * w, self.heads, self.head_dim).transpose(1, 2)\n","\n","        attn = (q @ k.transpose(-2, -1)) * self.scale\n","        attn = attn.softmax(dim=-1)\n","\n","        out = (attn @ v).transpose(1, 2).reshape(b, h * w, c)\n","        out = self.to_out(out).permute(0, 2, 1).view(b, c, h, w)\n","        return x + out\n","\n","\n","class ResBlock(nn.Module):\n","    def __init__(self, in_ch, out_ch, time_dim):\n","        super().__init__()\n","        self.conv1 = nn.Sequential(\n","            nn.GroupNorm(8, in_ch),\n","            nn.SiLU(),\n","            nn.Conv2d(in_ch, out_ch, 3, padding=1),\n","        )\n","        self.time_mlp = nn.Sequential(\n","            nn.SiLU(),\n","            nn.Linear(time_dim, out_ch),\n","        )\n","        self.conv2 = nn.Sequential(\n","            nn.GroupNorm(8, out_ch),\n","            nn.SiLU(),\n","            nn.Conv2d(out_ch, out_ch, 3, padding=1),\n","        )\n","        self.skip = nn.Conv2d(in_ch, out_ch, 1) if in_ch != out_ch else nn.Identity()\n","\n","    def forward(self, x, t_emb):\n","        h = self.conv1(x)\n","        h = h + self.time_mlp(t_emb)[:, :, None, None]\n","        h = self.conv2(h)\n","        return h + self.skip(x)\n","\n","\n","class LatentUNet(nn.Module):\n","    def __init__(self, in_ch=8, out_ch=4, base_ch=128, time_dim=256, sam2_feat_dim=256):\n","        super().__init__()\n","\n","        self.time_embed = SinusoidalTimeEmbedding(time_dim)\n","        self.sam2_proj = nn.Conv2d(sam2_feat_dim, 256, 1)\n","\n","        # Encoder\n","        self.enc1 = ResBlock(in_ch, base_ch, time_dim)\n","        self.down1 = nn.Conv2d(base_ch, base_ch, 4, 2, 1)\n","        self.enc2 = ResBlock(base_ch, base_ch * 2, time_dim)\n","        self.cross_attn_mid = SAM2CrossAttention(base_ch * 2, 256)\n","        self.down2 = nn.Conv2d(base_ch * 2, base_ch * 2, 4, 2, 1)\n","        self.enc3 = ResBlock(base_ch * 2, base_ch * 4, time_dim)\n","\n","        # Bottleneck\n","        self.bot1 = ResBlock(base_ch * 4, base_ch * 4, time_dim)\n","        self.cross_attn_bot = SAM2CrossAttention(base_ch * 4, 256)\n","        self.bot2 = ResBlock(base_ch * 4, base_ch * 4, time_dim)\n","\n","        # Decoder\n","        self.up1 = nn.ConvTranspose2d(base_ch * 4, base_ch * 2, 4, 2, 1)\n","        self.dec1 = ResBlock(base_ch * 4, base_ch * 2, time_dim)\n","        self.cross_attn_dec = SAM2CrossAttention(base_ch * 2, 256)\n","\n","        self.up2 = nn.ConvTranspose2d(base_ch * 2, base_ch, 4, 2, 1)\n","        self.dec2 = ResBlock(base_ch * 2, base_ch, time_dim)\n","\n","        self.out = nn.Sequential(\n","            nn.GroupNorm(8, base_ch),\n","            nn.SiLU(),\n","            nn.Conv2d(base_ch, out_ch, 3, padding=1),\n","        )\n","\n","    def forward(self, x_noisy, t, low_light_latent, sam2_features):\n","        x = torch.cat([x_noisy, low_light_latent], dim=1)\n","        t_emb = self.time_embed(t)\n","        sam2_feat = self.sam2_proj(sam2_features)\n","\n","        # Encoder - save sizes for matching later\n","        e1 = self.enc1(x, t_emb)\n","        d1 = self.down1(e1)\n","        e2 = self.enc2(d1, t_emb)\n","        e2 = self.cross_attn_mid(e2, sam2_feat)\n","        d2 = self.down2(e2)\n","        e3 = self.enc3(d2, t_emb)\n","\n","        # Bottleneck\n","        b = self.bot1(e3, t_emb)\n","        b = self.cross_attn_bot(b, sam2_feat)\n","        b = self.bot2(b, t_emb)\n","\n","        # Decoder - match spatial sizes to skip connections\n","        u1 = self.up1(b)\n","        u1 = F.interpolate(u1, size=e2.shape[2:], mode='bilinear', align_corners=False)\n","        u1 = torch.cat([u1, e2], dim=1)\n","        u1 = self.dec1(u1, t_emb)\n","        u1 = self.cross_attn_dec(u1, sam2_feat)\n","\n","        u2 = self.up2(u1)\n","        u2 = F.interpolate(u2, size=e1.shape[2:], mode='bilinear', align_corners=False)\n","        u2 = torch.cat([u2, e1], dim=1)\n","        u2 = self.dec2(u2, t_emb)\n","\n","        return self.out(u2)\n","\n","\n","# Test\n","model = LatentUNet().to('cuda')\n","total_params = sum(p.numel() for p in model.parameters()) / 1e6\n","print(f'Model created! Parameters: {total_params:.1f}M')\n","\n","dummy_noisy = torch.randn(1, 4, 50, 75).to('cuda')\n","dummy_t = torch.tensor([100]).to('cuda')\n","dummy_low = torch.randn(1, 4, 50, 75).to('cuda')\n","dummy_sam2 = torch.randn(1, 256, 64, 64).to('cuda')\n","\n","out = model(dummy_noisy, dummy_t, dummy_low, dummy_sam2)\n","print(f'Output shape: {out.shape}')\n","print('Forward pass successful! ✅')\n","\n","del dummy_noisy, dummy_t, dummy_low, dummy_sam2, out\n","torch.cuda.empty_cache()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"3H_0qVf3jThc","executionInfo":{"status":"ok","timestamp":1774737232478,"user_tz":240,"elapsed":245,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"}},"outputId":"0fd57be8-e055-467b-a327-a995a78d6f1d"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Model created! Parameters: 23.0M\n","Output shape: torch.Size([1, 4, 50, 75])\n","Forward pass successful! ✅\n"]}]},{"cell_type":"code","source":["from torch.utils.data import Dataset, DataLoader\n","import glob\n","\n","class LOLv2LatentDataset(Dataset):\n","    \"\"\"\n","    Loads precomputed VAE latents + SAM2 features from disk.\n","    No heavy models needed during training!\n","    \"\"\"\n","    def __init__(self, dataset_name='LOLv2_Real', split='Train'):\n","        self.latent_dir = os.path.join(PREPROC, 'vae_latents')\n","        self.feat_dir = os.path.join(PREPROC, 'sam2_features')\n","\n","        # Find all low-light input images to get the file names\n","        input_dir = os.path.join(DATASETS, f'{dataset_name}/{split}/Input')\n","        image_files = sorted(glob.glob(os.path.join(input_dir, '*.png')))\n","        image_files += sorted(glob.glob(os.path.join(input_dir, '*.jpg')))\n","\n","        # Build list of valid triplets (low latent, gt latent, sam2 feat)\n","        self.samples = []\n","        for img_path in image_files:\n","            name = os.path.splitext(os.path.basename(img_path))[0]\n","\n","            low_latent_path = os.path.join(self.latent_dir, f'Input_{name}.pt')\n","            gt_latent_path = os.path.join(self.latent_dir, f'GT_{name}.pt')\n","            sam2_feat_path = os.path.join(self.feat_dir, f'{name}.pt')\n","\n","            if all(os.path.exists(p) for p in [low_latent_path, gt_latent_path, sam2_feat_path]):\n","                self.samples.append((low_latent_path, gt_latent_path, sam2_feat_path))\n","\n","        print(f'{dataset_name}/{split}: Found {len(self.samples)} valid samples')\n","\n","    def __len__(self):\n","        return len(self.samples)\n","\n","    def __getitem__(self, idx):\n","        low_path, gt_path, feat_path = self.samples[idx]\n","\n","        low_latent = torch.load(low_path, weights_only=True).squeeze(0)   # (4, h, w)\n","        gt_latent = torch.load(gt_path, weights_only=True).squeeze(0)     # (4, h, w)\n","        sam2_feat = torch.load(feat_path, weights_only=True).squeeze(0)   # (256, h', w')\n","\n","        return low_latent, gt_latent, sam2_feat\n","\n","\n","# Test the dataset\n","train_dataset = LOLv2LatentDataset('LOLv2_Real', 'Train')\n","test_dataset = LOLv2LatentDataset('LOLv2_Real', 'Test')\n","\n","# Check one sample\n","low, gt, feat = train_dataset[0]\n","print(f'Low latent shape:  {low.shape}')\n","print(f'GT latent shape:   {gt.shape}')\n","print(f'SAM2 feat shape:   {feat.shape}')\n","print('Dataset ready! ✅')\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"677fCv-gkL5T","executionInfo":{"status":"ok","timestamp":1774737292756,"user_tz":240,"elapsed":26230,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"}},"outputId":"0e9573e9-ff09-4f01-afb6-77ae3cdbf56d"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["LOLv2_Real/Train: Found 689 valid samples\n","LOLv2_Real/Test: Found 100 valid samples\n","Low latent shape:  torch.Size([4, 50, 75])\n","GT latent shape:   torch.Size([4, 50, 75])\n","SAM2 feat shape:   torch.Size([256, 64, 64])\n","Dataset ready! ✅\n"]}]},{"cell_type":"code","source":["import csv\n","from torch.cuda.amp import autocast, GradScaler\n","\n","class DiffusionTrainer:\n","    def __init__(self, model, T=1000, beta_start=1e-4, beta_end=0.02):\n","        self.model = model\n","        self.T = T\n","\n","        # Noise schedule\n","        self.betas = torch.linspace(beta_start, beta_end, T).to('cuda')\n","        self.alphas = 1.0 - self.betas\n","        self.alpha_cumprod = torch.cumprod(self.alphas, dim=0)\n","        self.sqrt_alpha_cumprod = torch.sqrt(self.alpha_cumprod)\n","        self.sqrt_one_minus_alpha_cumprod = torch.sqrt(1.0 - self.alpha_cumprod)\n","\n","    def add_noise(self, x0, t, noise=None):\n","        \"\"\"Forward diffusion: add noise to clean latent.\"\"\"\n","        if noise is None:\n","            noise = torch.randn_like(x0)\n","\n","        sqrt_alpha = self.sqrt_alpha_cumprod[t][:, None, None, None]\n","        sqrt_one_minus = self.sqrt_one_minus_alpha_cumprod[t][:, None, None, None]\n","\n","        return sqrt_alpha * x0 + sqrt_one_minus * noise, noise\n","\n","    def train(self, train_dataset, num_epochs=200, lr=1e-4, batch_size=4,\n","              save_every=20, log_every=5):\n","\n","        save_dir = os.path.join(BASE, 'checkpoints', 'our_model')\n","        log_dir = os.path.join(BASE, 'training_logs')\n","        os.makedirs(save_dir, exist_ok=True)\n","        os.makedirs(log_dir, exist_ok=True)\n","\n","        dataloader = DataLoader(train_dataset, batch_size=batch_size,\n","                                shuffle=True, num_workers=2, pin_memory=True)\n","\n","        optimizer = torch.optim.AdamW(self.model.parameters(), lr=lr, weight_decay=1e-4)\n","        scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=num_epochs)\n","        scaler = GradScaler()\n","\n","        # Resume from checkpoint if exists\n","        start_epoch = 0\n","        log_path = os.path.join(log_dir, 'train_loss.csv')\n","        checkpoint_path = os.path.join(save_dir, 'latest.pt')\n","\n","        if os.path.exists(checkpoint_path):\n","            ckpt = torch.load(checkpoint_path, weights_only=False)\n","            self.model.load_state_dict(ckpt['model'])\n","            optimizer.load_state_dict(ckpt['optimizer'])\n","            scheduler.load_state_dict(ckpt['scheduler'])\n","            start_epoch = ckpt['epoch'] + 1\n","            print(f'Resumed from epoch {start_epoch}')\n","\n","        # Open log file\n","        if start_epoch == 0:\n","            log_file = open(log_path, 'w', newline='')\n","            writer = csv.writer(log_file)\n","            writer.writerow(['epoch', 'avg_loss', 'lr'])\n","        else:\n","            log_file = open(log_path, 'a', newline='')\n","            writer = csv.writer(log_file)\n","\n","        self.model.train()\n","        best_loss = float('inf')\n","\n","        for epoch in range(start_epoch, num_epochs):\n","            total_loss = 0\n","            num_batches = 0\n","\n","            pbar = tqdm(dataloader, desc=f'Epoch {epoch+1}/{num_epochs}')\n","            for low_latent, gt_latent, sam2_feat in pbar:\n","                low_latent = low_latent.to('cuda')\n","                gt_latent = gt_latent.to('cuda')\n","                sam2_feat = sam2_feat.to('cuda')\n","\n","                # Sample random timesteps\n","                t = torch.randint(0, self.T, (low_latent.shape[0],), device='cuda')\n","\n","                # Add noise to GT latent\n","                noisy_latent, noise = self.add_noise(gt_latent, t)\n","\n","                # Predict noise\n","                with autocast():\n","                    noise_pred = self.model(noisy_latent, t, low_latent, sam2_feat)\n","                    loss = F.mse_loss(noise_pred, noise)\n","\n","                optimizer.zero_grad()\n","                scaler.scale(loss).backward()\n","                scaler.unscale_(optimizer)\n","                torch.nn.utils.clip_grad_norm_(self.model.parameters(), 1.0)\n","                scaler.step(optimizer)\n","                scaler.update()\n","\n","                total_loss += loss.item()\n","                num_batches += 1\n","                pbar.set_postfix({'loss': f'{loss.item():.4f}'})\n","\n","            scheduler.step()\n","            avg_loss = total_loss / num_batches\n","            current_lr = scheduler.get_last_lr()[0]\n","\n","            # Log\n","            writer.writerow([epoch + 1, f'{avg_loss:.6f}', f'{current_lr:.8f}'])\n","            log_file.flush()\n","\n","            if (epoch + 1) % log_every == 0:\n","                print(f'Epoch {epoch+1}: loss={avg_loss:.4f}, lr={current_lr:.6f}')\n","\n","            # Save latest checkpoint (always, for resume)\n","            torch.save({\n","                'epoch': epoch,\n","                'model': self.model.state_dict(),\n","                'optimizer': optimizer.state_dict(),\n","                'scheduler': scheduler.state_dict(),\n","                'loss': avg_loss,\n","            }, checkpoint_path)\n","\n","            # Save best model\n","            if avg_loss < best_loss:\n","                best_loss = avg_loss\n","                torch.save(self.model.state_dict(),\n","                          os.path.join(save_dir, 'best.pt'))\n","                print(f'  ★ New best loss: {best_loss:.4f}')\n","\n","            # Save periodic checkpoint\n","            if (epoch + 1) % save_every == 0:\n","                torch.save(self.model.state_dict(),\n","                          os.path.join(save_dir, f'epoch_{epoch+1}.pt'))\n","                print(f'  Checkpoint saved: epoch_{epoch+1}.pt')\n","\n","        log_file.close()\n","        print(f'Training complete! Best loss: {best_loss:.4f}')\n","        return best_loss\n","\n","\n","trainer = DiffusionTrainer(model)\n","print('Trai