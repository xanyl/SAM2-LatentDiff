  alphas = 1.0 - betas\n","    alpha_cumprod = torch.cumprod(alphas, dim=0)\n","\n","    x = torch.randn_like(low_latent)\n","    timesteps = torch.linspace(T - 1, 0, num_steps).long().to('cuda')\n","\n","    for i in range(len(timesteps)):\n","        t = timesteps[i].unsqueeze(0)\n","\n","        with autocast():\n","            noise_pred = model(x, t, low_latent, sam2_feat)\n","        noise_pred = noise_pred.float()\n","\n","        alpha_t = alpha_cumprod[t.item()].view(1, 1, 1, 1)\n","\n","        x0_pred = (x - torch.sqrt(1 - alpha_t) * noise_pred) / torch.sqrt(alpha_t)\n","        x0_pred = x0_pred.clamp(-3, 3)\n","\n","        if i < len(timesteps) - 1:\n","            alpha_next = alpha_cumprod[timesteps[i + 1].item()].view(1, 1, 1, 1)\n","            x = torch.sqrt(alpha_next) * x0_pred + torch.sqrt(1 - alpha_next) * noise_pred\n","        else:\n","            x = x0_pred\n","\n","    return x\n","\n","print('Running DDIM sampling (50 steps)...')\n","enhanced_latent = ddim_sample(model, low_latent, sam2_feat)\n","\n","# Decode all three latents to images\n","def decode_latent(vae, latent):\n","    with torch.no_grad():\n","        img = vae.decode(latent.half() / 0.18215).sample\n","    return img.float().clamp(-1, 1) * 0.5 + 0.5\n","\n","img_low = decode_latent(vae, low_latent)\n","img_gt = decode_latent(vae, gt_latent)\n","img_ours = decode_latent(vae, enhanced_latent)\n","\n","fig, axes = plt.subplots(1, 3, figsize=(18, 6))\n","axes[0].imshow(img_low[0].cpu().permute(1, 2, 0).numpy())\n","axes[0].set_title('Low-Light Input')\n","axes[0].axis('off')\n","\n","axes[1].imshow(img_ours[0].cpu().permute(1, 2, 0).numpy())\n","axes[1].set_title('Our Enhanced')\n","axes[1].axis('off')\n","\n","axes[2].imshow(img_gt[0].cpu().permute(1, 2, 0).numpy())\n","axes[2].set_title('Ground Truth')\n","axes[2].axis('off')\n","\n","plt.tight_layout()\n","plt.savefig(os.path.join(BASE, 'outputs/sanity_check.png'), dpi=150)\n","plt.show()\n","\n","from skimage.metrics impor