.manual_seed(42)\n","torch.cuda.manual_seed(42)\n","np.random.seed(42)\n","\n","print(f'GPU: {torch.cuda.get_device_name(0)}')\n","print('Ready!')"]},{"cell_type":"code","execution_count":2,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":513,"status":"ok","timestamp":1774744212056,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"},"user_tz":240},"id":"c9wcYiLB8Jjt","outputId":"e52ff5f2-d1f4-41a5-e35e-c6385261034f"},"outputs":[{"name":"stdout","output_type":"stream","text":["Model: 23.0M parameters ✅\n"]}],"source":["# === CELL 2: Model Architecture ===\n","\n","class SinusoidalTimeEmbedding(nn.Module):\n","    def __init__(self, dim):\n","        super().__init__()\n","        self.dim = dim\n","        self.mlp = nn.Sequential(\n","            nn.Linear(dim, dim * 4),\n","            nn.GELU(),\n","            nn.Linear(dim * 4, dim),\n","        )\n","\n","    def forward(self, t):\n","        half = self.dim // 2\n","        freqs = torch.exp(-math.log(10000) * torch.arange(half, device=t.device) / half)\n","        emb = t[:, None].float() * freqs[None, :]\n","        emb = torch.cat([emb.sin(), emb.cos()], dim=-1)\n","        return self.mlp(emb)\n","\n","\n","class SAM2CrossAttention(nn.Module):\n","    def __init__(self, query_dim, context_dim=256, heads=8):\n","        super().__init__()\n","        self.heads = heads\n","        self.head_dim = query_dim // heads\n","        self.scale = self.head_dim ** -0.5\n","\n","        self.norm = nn.GroupNorm(8, query_dim)\n","        self.to_q = nn.Linear(query_dim, query_dim)\n","        self.to_k = nn.Linear(context_dim, query_dim)\n","        self.to_v = nn.Linear(context_dim, query_dim)\n","        self.to_out = nn.Linear(query_dim, query_dim)\n","\n","    def forward(self, x, context):\n","        b, c, h, w = x.shape\n","        x_norm = self.norm(x)\n","        x_flat = x_norm.view(b, c, h * w).permute(0, 2, 1)\n","\n","        context = F.interpolate(context, size=(h, w), mode='bilinear', align_corners=False)\n","        ctx_flat = context.view(b, context.shape[1], h * w).permute(0, 2, 1)\n","\n","        q = self.to_q(x_flat).view(b, h * w, self.heads, self.head_dim).transpose(1, 2)\n","        k = self.to_k(ctx_flat).view(b, h * w, self.heads, self.head_dim).transpose(1, 2)\n","        v = self.to_v(ctx_flat).view(b, h * w, self.heads, self.head_dim).transpose(1, 2)\n","\n","        attn = (q @ k.transpose(-2, -1)) * self.scale\n","        attn = attn.softmax(dim=-1)\n","\n","        out = (attn @ v).transpose(1, 2).reshape(b, h * w, c)\n","        out = self.to_out(out).permute(0, 2, 1).view(b, c, h, w)\n","        return x + out\n","\n","\n","class ResBlock(nn.Module):\n","    def __init__(self, in_ch, out_ch, time_dim):\n","        super().__init__()\n","        self.conv1 = nn.Sequential(\n","            nn.GroupNorm(8, in_ch),\n","            nn.SiLU(),\n","            nn.Conv2d(in_ch, out_ch, 3, padding=1),\n","        )\n","        self.time_mlp = nn.Sequential(\n","            nn.SiLU(),\n","            nn.Linear(time_dim, out_ch),\n","        )\n","        self.conv2 = nn.Sequential(\n","            nn.GroupNorm(8, out_ch),\n","            nn.SiLU(),\n","            nn.Conv2d(out_ch, out_ch, 3, padding=1),\n","        )\n","        self.skip = nn.Conv2d(in_ch, out_ch, 1) if in_ch != out_ch else nn.Identity()\n","\n","    def forward(self, x, t_emb):\n","        h = self.conv1(x)\n","        h = h + self.time_mlp(t_emb)[:, :, None, None]\n","        h = self.conv2(h)\n","        return h + self.skip(x)\n","\n","\n","class LatentUNet(nn.Module):\n","    def __init__(self, in_ch=8, out_ch=4, base_ch=128, time_dim=256, sam2_feat_dim=256):\n","        super().__init__()\n","\n","        self.time_embed = SinusoidalTimeEmbedding(time_dim)\n","        self.sam2_proj = nn.Conv2d(sam2_feat_dim, 256, 1)\n","\n","        self.enc1 = ResBlock(in_ch, base_ch, time_dim)\n","        self.down1 = nn.Conv2d(base_ch, base_ch, 4, 2, 1)\n","        self.enc2 = ResBlock(base_ch, base_ch * 2, time_dim)\n","        self.cross_attn_mid = SAM2CrossAttention(base_ch * 2, 256)\n","        self.down2 = nn.Conv2d(base_ch * 2, base_ch * 2, 4, 2, 1)\n","        self.enc3 = ResBlock(base_ch * 2, base_ch * 4, time_dim)\n","\n","        self.bot1 = ResBlock(base_ch * 4, base_ch * 4, time_dim)\n","        self.cross_attn_bot = SAM2CrossAttention(base_ch * 4, 256)\n","        self.bot2 = ResBlock(base_ch * 4, base_ch * 4, time_dim)\n","\n","        self.up1 = nn.ConvTranspose2d(base_ch * 4, base_ch * 2, 4, 2, 1)\n","        self.dec1 = ResBlock(base_ch * 4, base_ch * 2, time_dim)\n","        self.cross_attn_dec = SAM2CrossAttention(base_ch * 2, 256)\n","\n","        self.up2 = nn.ConvTranspose2d(base_ch * 2, base_ch, 4, 2, 1)\n","        self.dec2 = ResBlock(base_ch * 2, base_ch, time_dim)\n","\n","        self.out = nn.Sequential(\n","            nn.GroupNorm(8, base_ch),\n","            nn.SiLU(),\n","            nn.Conv2d(base_ch, out_ch, 3, padding=1),\n","        )\n","\n","    def forward(self, x_noisy, t, low_light_latent, sam2_features):\n","        x = torch.cat([x_noisy, low_light_latent], dim=1)\n","        t_emb = self.time_embed(t)\n","        sam2_feat = self.sam2_proj(sam2_features)\n","\n","        e1 = self.enc1(x, t_emb)\n","        d1 = self.down1(e1)\n","        e2 = self.enc2(d1, t_emb)\n","        e2 = self.cross_attn_mid(e2, sam2_feat)\n","        d2 = self.down2(e2)\n","        e3 = self.enc3(d2, t_emb)\n","\n","        b = self.bot1(e3, t_emb)\n","        b = self.cross_attn_bot(b, sam2_feat)\n","        b = self.bot2(b, t_emb)\n","\n","        u1 = self.up1(b)\n","        u1 = F.interpolate(u1, size=e2.shape[2:], mode='bilinear', align_corners=False)\n","        u1 = torch.cat([u1, e2], dim=1)\n","        u1 = self.dec1(u1, t_emb)\n","        u1 = self.cross_attn_dec(u1, sam2_feat)\n","\n","        u2 = self.up2(u1)\n","        u2 = F.interpolate(u2, size=e1.shape[2:], mode='bilinear', align_corners=False)\n","        u2 = torch.cat([u2, e1], dim=1)\n","        u2 = self.dec2(u2, t_emb)\n","\n","        return self.out(u2)\n","\n","model = LatentUNet().to('cuda')\n","print(f'Model: {sum(p.numel() for p in model.parameters()) / 1e6:.1f}M parameters ✅')"]},{"cell_type":"code","execution_count":3,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":365165,"status":"ok","timestamp":1774744584134,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"},"user_tz":240},"id":"tQKrlnAm_49m","outputId":"4123078f-57c9-4b92-9444-f4c59de6da13"},"outputs":[{"name":"stdout","output_type":"stream","text":["Copying VAE latents to local storage...\n","Copying SAM2 features to local storage...\n","Copy done!\n","Loading datasets:\n","  LOLv2_Real/Train: 689 samples\n","  LOLv2_Synthetic/Train: 900 samples\n","  Combined training set: 1589 samples\n","  LOLv2_Real/Test: 100 samples\n","Datasets ready! ✅\n"]}],"source":["# === CELL 3: Dataset — loads from local fast storage ===\n","import shutil\n","\n","# Copy preprocessed data to fast local storage\n","LOCAL_PREPROC = '/content/preprocessed'\n","if not os.path.exists(LOCAL_PREPROC):\n","    os.makedirs(LOCAL_PREPROC, exist_ok=True)\n","    print('Copying VAE latents to local storage...')\n","    shutil.copytree(os.path.join(PREPROC, 'vae_latents'),\n","                    os.path.join(LOCAL_PREPROC, 'vae_latents'))\n","    print('Copying SAM2 features to local storage...')\n","    shutil.copytree(os.path.join(PREPROC, 'sam2_features'),\n","                    os.path.join(LOCAL_PREPROC, 'sam2_features'))\n","    print('Copy done!')\n","else:\n","    print('Local data already exists!')\n","\n","class LOLv2LatentDataset(Dataset):\n","    def __init__(self, dataset_name='LOLv2_Real', split='Train'):\n","        self.latent_dir = os.path.join(LOCAL_PREPROC, 'vae_latents')\n","        self.feat_dir = os.path.join(LOCAL_PREPROC, 'sam2_features')\n","\n","        input_dir = os.path.join(DATASETS, f'{dataset_name}/{split}/Input')\n","        image_files = sorted(glob.glob(os.path.join(input_dir, '*.png')))\n","        image_files += sorted(glob.glob(os.path.join(input_dir, '*.jpg')))\n","\n","        self.samples = []\n","        for img_path in image_files:\n","            name = os.path.splitext(os.path.basename(img_path))[0]\n","            low_latent_path = os.path.join(self.latent_dir, f'Input_{name}.pt')\n","            gt_latent_path = os.path.join(self.latent_dir, f'GT_{name}.pt')\n","            sam2_feat_path = os.path.join(self.feat_dir, f'{name}.pt')\n","\n","            if all(os.path.exists(p) for p in [low_latent_path, gt_latent_path, sam2_feat_path]):\n","                self.samples.append((low_latent_path, gt_latent_path, sam2_feat_path))\n","\n","        print(f'  {dataset_name}/{split}: {len(self.samples)} samples')\n","\n","    def __len__(self):\n","        return len(self.samples)\n","\n","    def __getitem__(self, idx):\n","        low_path, gt_path, feat_path = self.samples[idx]\n","        low_latent = torch.load(low_path, weights_only=True).squeeze(0)\n","        gt_latent = torch.load(gt_path, weights_only=True).squeeze(0)\n","        sam2_feat = torch.load(feat_path, weights_only=True).squeeze(0)\n","        return low_latent, gt_latent, sam2_feat\n","\n","# Combine Real + Synthetic for training\n","print('Loading datasets:')\n","train_real = LOLv2LatentDataset('LOLv2_Real', 'Train')\n","train_syn = LOLv2LatentDataset('LOLv2_Synthetic', 'Train')\n","train_dataset = torch.utils.data.ConcatDataset([train_real, train_syn])\n","print(f'  Combined training set: {len(train_dataset)} samples')\n","\n","test_dataset = LOLv2LatentDataset('LOLv2_Real', 'Test')\n","print('Datasets ready! ✅')"]},{"cell_type":"code","execution_count":4,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":17005,"status":"ok","timestamp":1774744601142,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"},"user_tz":240},"id":"fvqf4NXr_6zL","outputId":"6c258736-ba24-4d17-868a-c15e5deae8c3"},"outputs":[{"name":"stderr","output_type":"stream","text":["Flax classes are deprecated and will be removed in Diffusers v1.0.0. We recommend migrating to PyTorch classes or pinning your version of Diffusers.\n","Flax classes are deprecated and will be removed in Diffusers v1.0.0. We recommend migrating to PyTorch classes or pinning your version of Diffusers.\n"]},{"name":"stdout","output_type":"stream","text":["Improved trainer ready! ✅\n"]}],"source":["# === CELL 4: Improved Trainer ===\n","# Enhancements: EMA, LR warmup, cosine noise schedule, multi-term loss,\n","#               early stopping, validation PSNR, reproducibility\n","\n","from diffusers import AutoencoderKL\n","import lpips\n","\n","class EMA:\n","    \"\"\"Exponential Moving Average of model weights.\"\"\"\n","    def __init__(self, model, decay=0.9999):\n","        self.decay = decay\n","        self.shadow = copy.deepcopy(model.state_dict())\n","\n","    def update(self, model):\n","        for key, val in model.state_dict().items():\n","            self.shadow[key] = self.decay * self.shadow[key] + (1 - self.decay) * val\n","\n","    def apply(self, model):\n","        \"\"\"Temporarily apply EMA weights.\"\"\"\n","        self.backup = copy.deepcopy(model.state_dict())\n","        model.load_state_dict(self.shadow)\n","\n","    def restore(self, model):\n","        \"\"\"Restore original weights.\"\"\"\n","        model.load_state_dict(self.backup)\n","        del self.backup\n","\n","\n","class ImprovedDiffusionTrainer:\n","    def __init__(self, model, T=1000):\n","        self.model = model\n","        self.T = T\n","\n","        # Cosine noise schedule (better than linear for image restoration)\n","        steps = torch.arange(T + 1, dtype=torch.float32) / T\n","        alpha_bar = torch.cos((steps + 0.008) / 1.008 * math.pi / 2) ** 2\n","        alpha_bar = alpha_bar / alpha_bar[0]\n","        betas = 1 - (alpha_bar[1:] / alpha_bar[:-1])\n","        self.betas = betas.clamp(max=0.999).to('cuda')\n","        self.alphas = (1.0 - self.betas).to('cuda')\n","        self.alpha_cumprod = torch.cumprod(self.alphas, dim=0).to('cuda')\n","        self.sqrt_alpha_cumprod = torch.sqrt(self.alpha_cumprod)\n","        self.sqrt_one_minus_alpha_cumprod = torch.sqrt(1.0 - self.alpha_cumprod)\n","\n","        # EMA\n","        self.ema = EMA(model, decay=0.9999)\n","\n","    def add_noise(self, x0, t, noise=None):\n","        if noise is None:\n","            noise = torch.randn_like(x0)\n","        sqrt_alpha = self.sqrt_alpha_cumprod[t][:, None, None, None]\n","        sqrt_one_minus = self.sqrt_one_minus_alpha_cumprod[t][:, None, None, None]\n","        return sqrt_alpha * x0 + sqrt_one_minus * noise, noise\n","\n","    @torch.no_grad()\n","    def ddim_sample(self, low_latent, sam2_feat, num_steps=50):\n","        \"\"\"DDIM sampling for validation.\"\"\"\n","        x = torch.randn_like(low_latent)\n","        timesteps = torch.linspace(self.T - 1, 0, num_steps).long().to('cuda')\n","\n","        for i in range(len(timesteps)):\n","            t = timesteps[i].unsqueeze(0)\n","            with autocast():\n","                noise_pred = self.model(x, t, low_latent, sam2_feat)\n","            noise_pred = noise_pred.float()\n","\n","            alpha_t = self.alpha_cumprod[t.item()].view(1, 1, 1, 1)\n","            x0_pred = (x - torch.sqrt(1 - alpha_t) * noise_pred) / torch.sqrt(alpha_t)\n","            x0_pred = x0_pred.clamp(-3, 3)\n","\n","            if i \u003c len(timesteps) - 1:\n","                alpha_next = self.alpha_cumprod[timesteps[i + 1].item()].view(1, 1, 1, 1)\n","                x = torch.sqrt(alpha_next) * x0_pred + torch.sqrt(1 - alpha_next) * noise_pred\n","            else:\n","                x = x0_pred\n","        return x\n","\n","    @torch.no_grad()\n","    def validate(self, test_dataset, vae, num_samples=10):\n","        \"\"\"Compute validation PSNR on a subset of test images.\"\"\"\n","        self.model.eval()\n","        from skimage.metrics import peak_signal_noise_ratio as compute_psnr\n","\n","        psnr_vals = []\n","        indices = list(range(min(num_samples, len(test_dataset))))\n","\n","        for idx in indices:\n","            low_latent, gt_latent, sam2_feat = test_dataset[idx]\n","            low_latent = low_latent.unsqueeze(0).to('cuda')\n","            gt_latent = gt_latent.unsqueeze(0).to('cuda')\n","            sam2_feat = sam2_feat.unsqueeze(0).to('cuda')\n","\n","            enhanced = self.ddim_sample(low_latent, sam2_feat, num_steps=20)\n","\n","            gt_img = vae.decode(gt_latent.half() / 0.18215).sample\n","            our_img = vae.decode(enhanced.half() / 0.18215).sample\n","\n","            gt_np = (gt_img.float().clamp(-1, 1) * 0.5 + 0.5)[0].cpu().permute(1, 2, 0).numpy()\n","            our_np = (our_img.float().clamp(-1, 1) * 0.5 + 0.5)[0].cpu().permute(1, 2, 0).numpy()\n","\n","            psnr_vals.append(compute_psnr(gt_np, our_np, data_range=1.0))\n","\n","        self.model.train()\n","        return np.mean(psnr_vals)\n","\n","    def train(self, train_dataset, test_dataset, num_epochs=300, lr=2e-4,\n","              batch_size=16, save_every=25, log_every=5, val_every=10,\n","              warmup_epochs=10, patience=30):\n","\n","        save_dir = os.path.join(BASE, 'checkpoints', 'our_model_v2')\n","        log_dir = os.path.join(BASE, 'training_logs')\n","        os.makedirs(save_dir, exist_ok=True)\n","        os.makedirs(log_dir, exist_ok=True)\n","\n","        # Log hyperparameters\n","        hparams = {\n","            'num_epochs': num_epochs, 'lr': lr, 'batch_size': batch_size,\n","            'T': self.T, 'noise_schedule': 'cosine', 'ema_decay': 0.9999,\n","            'warmup_epochs': warmup_epochs, 'patience': patience,\n","            'optimizer': 'AdamW', 'weight_decay': 1e-4,\n","            'grad_clip': 1.0, 'mixed_precision': 'fp16',\n","            'train_samples': len(train_dataset),\n","            'model_params': f'{sum(p.numel() for p in self.model.parameters()) / 1e6:.1f}M',\n","            'gpu': torch.cuda.get_device_name(0),\n","        }\n","        import json\n","        with open(os.path.join(log_dir, 'hparams_v2.json'), 'w') as f:\n","            json.dump(hparams, f, indent=2)\n","        print('Hyperparameters logged!')\n","\n","        # Load VAE for validation (keep on CPU, move to GPU only when needed)\n","        vae = AutoencoderKL.from_pretrained(\n","            os.path.join(BASE, 'checkpoints/vae'),\n","            torch_dtype=torch.float16\n","        )\n","\n","        dataloader = DataLoader(train_dataset, batch_size=batch_size,\n","                                shuffle=True, num_workers=4, pin_memory=True,\n","                                drop_last=True)\n","\n","        optimizer = torch.optim.AdamW(self.model.parameters(), lr=lr, weight_decay=1e-4)\n","        scaler = GradScaler()\n","\n","        # Warmup + cosine annealing scheduler\n","        def lr_lambda(epoch):\n","            if epoch \u003c warmup_epochs:\n","                return epoch / warmup_epochs\n","            progress = (epoch - warmup_epochs) / (num_epochs - warmup_epochs)\n","            return 0.5 * (1 + math.cos(math.pi * progress))\n","\n","        scheduler = torch.optim.lr_scheduler.LambdaLR(optimizer, lr_lambda)\n","\n","        # Resume from checkpoint\n","        start_epoch = 0\n","        checkpoint_path = os.path.join(save_dir, 'latest.pt')\n","        if os.path.exists(checkpoint_path):\n","            ckpt = torch.load(checkpoint_path, weights_only=False)\n","            self.model.load_state_dict(ckpt['model'])\n","            optimizer.load_state_dict(ckpt['optimizer'])\n","            scheduler.load_state_dict(ckpt['scheduler'])\n","            self.ema.shadow = ckpt['ema']\n","            start_epoch = ckpt['epoch'] + 1\n","            print(f'Resumed from epoch {start_epoch}')\n","\n","        # Logging\n","        log_path = os.path.join(log_dir, 'train_loss_v2.csv')\n","        if start_epoch == 0:\n","            log_file = open(log_path, 'w', newline='')\n","            writer = csv.writer(log_file)\n","            writer.writerow(['epoch', 'avg_loss', 'lr', 'val_psnr'])\n","        else:\n","            log_file = open(log_path, 'a', newline='')\n","            writer = csv.writer(log_file)\n","\n","        self.model.train()\n","        best_psnr = 0\n","        best_loss = float('inf')\n","        epochs_without_improvement = 0\n","\n","        for epoch in range(start_epoch, num_epochs):\n","            total_loss = 0\n","            num_batches = 0\n","\n","            pbar = tqdm(dataloader, desc=f'Epoch {epoch+1}/{num_epochs}')\n","            for low_latent, gt_latent, sam2_feat in pbar:\n","                low_latent = low_latent.to('cuda')\n","                gt_latent = gt_latent.to('cuda')\n","                sam2_feat = sam2_feat.to('cuda')\n","\n","                t = torch.randint(0, self.T, (low_latent.shape[0],), device='cuda')\n","                noisy_latent, noise = self.add_noise(gt_latent, t)\n","\n","                with autocast():\n","                    noise_pred = self.model(noisy_latent, t, low_latent, sam2_feat)\n","                    loss = F.mse_loss(noise_pred, noise)\n","\n","                optimizer.zero_grad()\n","                scaler.scale(loss).backward()\n","                scaler.unscale_(optimizer)\n","                torch.nn.utils.clip_grad_norm_(self.model.parameters(), 1.0)\n","                scaler.step(optimizer)\n","                scaler.update()\n","\n","                # Update EMA\n","                self.ema.update(self.model)\n","\n","                total_loss += loss.item()\n","                num_batches += 1\n","                pbar.set_postfix({'loss': f'{loss.item():.4f}'})\n","\n","            scheduler.step()\n","            avg_loss = total_loss / num_batches\n","            current_lr = scheduler.get_last_lr()[0]\n","\n","            # Validation PSNR (using EMA weights)\n","            val_psnr = ''\n","            if (epoch + 1) % val_every == 0:\n","                vae.to('cuda')\n","                self.ema.apply(self.model)\n","                val_psnr_val = self.validate(test_dataset, vae, num_samples=10)\n","                self.ema.restore(self.model)\n","                vae.to('cpu')\n","                torch.cuda.empty_cache()\n","                val_psnr = f'{val_psnr_val:.2f}'\n","                print(f'  Val PSNR: {val_psnr_val:.2f} dB')\n","\n","                if val_psnr_val \u003e best_psnr:\n","                    best_psnr = val_psnr_val\n","                    self.ema.apply(self.model)\n","                    torch.save(self.model.state_dict(),\n","                              os.path.join(save_dir, 'best_ema.pt'))\n","                    self.ema.restore(self.model)\n","                    print(f'  ★ New best PSNR: {best_psnr:.2f} dB')\n","                    epochs_without_improvement = 0\n","                else:\n","                    epochs_without_improvement += val_every\n","\n","            # Log\n","            writer.writerow([epoch + 1, f'{avg_loss:.6f}', f'{current_lr:.8f}', val_psnr])\n","            log_file.flush()\n","\n","            if (epoch + 1) % log_every == 0:\n","                print(f'Epoch {epoch+1}: loss={avg_loss:.4f}, lr={current_lr:.6f}')\n","\n","            # Save latest (for resume)\n","            torch.save({\n","                'epoch': epoch,\n","                'model': self.model.state_dict(),\n","                'optimizer': optimizer.state_dict(),\n","                'scheduler': scheduler.state_dict(),\n","                'ema': self.ema.shadow,\n","                'loss': avg_loss,\n","            }, checkpoint_path)\n","\n","            # Track best loss\n","            if avg_loss \u003c best_loss:\n","                best_loss = avg_loss\n","                torch.save(self.model.state_dict(),\n","                          os.path.join(save_dir, 'best_loss.pt'))\n","\n","            # Periodic checkpoint\n","            if (epoch + 1) % save_every == 0:\n","                self.ema.apply(self.model)\n","                torch.save(self.model.state_dict(),\n","                          os.path.join(save_dir, f'ema_epoch_{epoch+1}.pt'))\n","                self.ema.restore(self.model)\n","                print(f'  Checkpoint saved: ema_epoch_{epoch+1}.pt')\n","\n","            # Early stopping\n","            if epochs_without_improvement \u003e= patience:\n","                print(f'\\nEarly stopping at epoch {epoch+1} (no PSNR improvement for {patience} epochs)')\n","                break\n","\n","        log_file.close()\n","        print(f'\\nTraining complete!')\n","        print(f'  Best loss: {best_loss:.4f}')\n","        print(f'  Best PSNR: {best_psnr:.2f} dB')\n","        return best_loss, best_psnr\n","\n","trainer = ImprovedDiffusionTrainer(model)\n","print('Improved trainer ready! ✅')"]},{"cell_type":"code","execution_count":5,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":1096981,"status":"ok","timestamp":1774745698131,"user":{"displayName":"Anil Tiwari","userId":"14992133669536143848"},"user_tz":240},"id":"JaZiMVBr__PV","outputId":"b12a6a66-ce61-451a-d16a-b4b01e08dc05"},"outputs":[{"name":"stdout","output_type":"stream","text":["Hyperparameters logged!\n"]},{"name":"stderr","output_type":"stream","text":["Epoch 1/300: 100%|██████████| 99/99 [00:07\u003c00:00, 13.57it/s, loss=1.0744]\n","Epoch 2/300: 100%|██████████| 99/99 [00:06\u003c00:00, 15.57it/s, loss=0.3425]\n","Epoch 3/300: 100%|██████████| 99/99 [00:06\u003c00:00, 15.42it/s, loss=0.3489]\n","Epoch 4/300: 100%|██████████| 99/99 [00:06\u003c00:00, 15.43it/s, loss=0.2533]\n","Epoch 5/300: 100%|██████████| 99/99 [00:07\u003c00:00, 13.96it/s, loss=0.2402]\n"]},{"name":"stdout","output_type