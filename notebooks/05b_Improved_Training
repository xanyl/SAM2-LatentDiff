1]\n","Epoch 124/300: 100%|██████████| 99/99 [00:06\u003c00:00, 14.92it/s, loss=0.1647]\n","Epoch 125/300: 100%|██████████| 99/99 [00:06\u003c00:00, 15.23it/s, loss=0.0920]\n"]},{"name":"stdout","output_type":"stream","text":["Epoch 125: loss=0.1158, lr=0.000132\n","  Checkpoint saved: ema_epoch_125.pt\n"]},{"name":"stderr","output_type":"stream","text":["Epoch 126/300: 100%|██████████| 99/99 [00:13\u003c00:00,  7.15it/s, loss=0.0623]\n","Epoch 127/300: 100%|██████████| 99/99 [00:14\u003c00:00,  6.66it/s, loss=0.1074]\n","Epoch 128/300: 100%|██████████| 99/99 [00:06\u003c00:00, 15.21it/s, loss=0.1336]\n","Epoch 129/300: 100%|██████████| 99/99 [00:10\u003c00:00,  9.68it/s, loss=0.0655]\n","Epoch 130/300: 100%|██████████| 99/99 [00:06\u003c00:00, 14.88it/s, loss=0.1442]\n"]},{"name":"stdout","output_type":"stream","text":["  Val PSNR: 10.07 dB\n","Epoch 130: loss=0.1153, lr=0.000127\n","\n","Early stopping at epoch 130 (no PSNR improvement for 30 epochs)\n","\n","Training complete!\n","  Best loss: 0.1125\n","  Best PSNR: 10.52 dB\n"]}],"source":["# === CELL 5: Train! ===\n","best_loss, best_psnr = trainer.train(\n","    train_dataset,\n","    test_dataset,\n","    num_epochs=300,\n","    lr=2e-4,\n","    batch_size=16,\n","    save_every=25,\n","    log_every=5,\n","    val_every=10,\n","    warmup_epochs=10,\n","    patience=30,\n",")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true,"base_uri":"https://localhost:8080/","output_embedded_package_id":"1mPNxTPliMoPxzR2Af2KDXTXmZe6KDoOb"},"id":"MPoFEVpcAB4q","outputId":"45c410aa-dd07-48f9-9648-03621b77d43b"},"outputs":[],"source":["# === Visual check with best EMA checkpoint ===\n","from diffusers import AutoencoderKL\n","import matplotlib.pyplot as plt\n","\n","# Load best EMA checkpoint\n","model.load_state_dict(torch.load(\n","    os.path.join(BASE, 'checkpoints/our_model_v2/best_ema.pt'),\n","    weights_only=True\n","))\n","model.eval()\n","\n","# Load VAE\n","vae = AutoencoderKL.from_pretrained(\n","    os.path.join(BASE, 'checkpoints/vae'),\n","    torch_dtype=torch.float16\n",").to('cuda')\n","vae.eval()\n","\n","# DDIM sampler\n","@torch.no_grad()\n","def ddim_sample(model, low_latent, sam2_feat, num_steps=50, T=1000):\n","    # Cosine schedule (same as training)\n","    steps = torch.arange(T + 1, dtype=torch.float32) / T\n","    alpha_bar = torch.cos((steps + 0.008) / 1.008 * math.pi / 2) ** 2\n","    alpha_bar = alpha_bar / alpha_bar[0]\n","    alpha_cumprod = alpha_bar[1:].to('cuda')\n","\n","    x = torch.randn_like(low_latent)\n","    timesteps = torch.linspace(T - 1, 0, num_steps).long().to('cuda')\n","\n","    for i in range(len(timesteps)):\n","        t = timesteps[i].unsqueeze(0)\n","        with autocast():\n","            noise_pred = model(x, t, low_latent, sam2_feat)\n","        noise_pred = noise_pred.float()\n","\n","        alpha_t = alpha_cumprod[t.item()].view(1, 1, 1, 1)\n","        x0_pred = (x - torch.sqrt(1 - alpha_t) * noise_pred) / torch.sqrt(alpha_t)\n","        x0_pred = x0_pred.clamp(-3, 3)\n","\n","        if i \u003c len(timesteps) - 1:\n","            alpha_next = alpha_cumprod[timesteps[i + 1].item()].view(1, 1, 1, 1)\n","            x = torch.sqrt(alpha_next) * x0_pred + torch.sqrt(1 - alpha_next) * noise_pred\n","        else:\n","            x = x0_pred\n","    return x\n","\n","def decode_latent(vae, latent):\n","    with torch.no_grad():\n","        img = vae.decode(latent.half() / 0.18215).sample\n","    return img.float().clamp(-1, 1) * 0.5 + 0.5\n","\n","# Test on 5 samples\n","from skimage.metrics import peak_signal_noise_ratio as compute_psnr\n","\n","fig, axes = plt.subplots(5, 3, figsize=(18, 30))\n","axes[0, 0].set_title('Low-Light Input', fontsize=14)\n","axes[0, 1].set_title('Our Enhanced', fontsize=14)\n","axes[0, 2].set_title('Ground Truth', fontsize=14)\n","\n","for idx in range(5):\n","    low_latent, gt_latent, sam2_feat = test_dataset[idx]\n","    low_latent = low_latent.unsqueeze(0).to('cuda')\n","    gt_latent = gt_latent.unsqueeze(0).to('cuda')\n","    sam2_feat = sam2_feat.unsqueeze(0).to('cuda')\n","\n","    enhanced = ddim_sample(model, low_latent, sam2_feat)\n","\n","    img_low = decode_latent(vae, low_latent)\n","    img_ours = decode_latent(vae, enhanced)\n","    img_gt = decode_latent(vae, gt_latent)\n","\n","    p = compute_psnr(\n","        img_gt[0].cpu().permute(1, 2, 0).numpy(),\n","        img_ours[0].cpu().permute(1, 2, 0).numpy(),\n","        data_range=1.0\n","    )\n","\n","    axes[idx, 0].imshow(img_low[0].cpu().permute(1, 2, 0).numpy())\n","    axes[idx, 0].axis('off')\n","\n","    axes[idx, 1].imshow(img_ours[0].cpu().permute(1, 2, 0).numpy())\n","    axes[idx, 1].set_ylabel(f'PSNR: {p:.1f}', fontsize=12)\n","    axes[idx, 1].axis('off')\n","\n","    axes[idx, 2].imshow(img_gt[0].cpu().permute(1, 2, 0).numpy())\n","    axes[idx, 2].axis('off')\n","\n","    print(f'Sample {idx+1}: PSNR = {p:.2f} dB')\n","\n","plt.tight_layout()\n","os.makedirs(os.path.join(BASE, 'outputs'), exist_ok=True)\n","plt.savefig(os.path.join(BASE, 'outputs/v2_results.png'), dpi=150)\n","plt.show()\n","print('Saved to outputs/v2_results.png')\n","\n","del vae\n","torch.cuda.empty_cache()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"1zU-VglmGYCv"},"outputs":[],"source":[]}],"metadata":{"accelerator":"GPU","colab":{"authorship_tag":"ABX9TyNtxuVfUGjnKFk3s/K88Rbh","gpuType":"A100","name":"","version":""},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}